---

<footer class="bg-neutral-900 text-neutral-300">
	<div class="mx-auto grid max-w-6xl gap-10 px-6 py-16 sm:grid-cols-2">
		<div>
			<h2 class="font-display text-3xl italic tracking-wide text-white">Follow me</h2>
			<ul class="mt-5 flex items-center gap-5">
				{
					socials.map(({ label, href, icon }) => (
						<li>
							<a
								href={href}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={`Go to ${label} page`}
								class="text-neutral-400 transition-colors hover:text-sand"
							>
								<svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
									<path d={icon} />
								</svg>
							</a>
						</li>
					))
				}
			</ul>
		</div>
		<div class="sm:text-right">
			<p class="leading-relaxed">
				Notting Hill<br />
				London, United Kingdom.
			</p>
		</div>
	</div>
	<div class="border-t border-neutral-800 py-6 text-center text-sm text-neutral-400">
		© {year} by Sabina D'Ercole.
	</div>
</footer>
