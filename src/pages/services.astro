---
import Layout from '../layouts/Layout.astro';
import Placeholder from '../components/Placeholder.astro';

const offerings = [
	{
		title: 'Min Gua',
		text: 'The study of feng shui at a personal level, which can be developed through consulting.',
	},
	{
		title: 'Micro Feng Shui',
		text: 'A calculation of your personal specific directions (defined as the degrees in a compass) which outlines your best orientations.',
	},
	{
		title: 'Branding',
		text: 'A tailor-made study of the best possible image for your business based on feng shui’s principles.',
	},
];

const testimonials = [
	{
		quote:
			'It was beautiful to apply feng shui to our Christmas dinner and see how the place felt.',
		author: 'Alex Green & Elisa Rosas',
	},
	{
		quote:
			'We could feel a real difference in our space that was also transmitted to our relationship as a family.',
		author: 'Cesar Sanchez & Sofía Lopez',
	},
];
---

<Layout title="Expert Feng Shui Consulting Services for Personal and Business | Sabina Dercole">
	<!-- Hero -->
	<section class="relative">
		<Placeholder
			alt="Hand drawing over an architectural floor plan with a pen beside a laptop"
			class="h-[55vh] min-h-[360px] w-full"
		/>
		<div class="absolute inset-0 flex items-end justify-center pb-12">
			<h1
				class="bg-white/85 px-10 py-4 font-display text-3xl tracking-[0.15em] text-neutral-900 uppercase backdrop-blur-sm sm:text-4xl"
			>
				Services
			</h1>
		</div>
	</section>

	<!-- Personal Feng Shui offerings -->
	<section class="mx-auto max-w-6xl px-6 py-20">
		<h2 class="text-center font-display text-5xl text-sand italic">Personal Feng Shui</h2>
		<p class="mt-4 text-center text-lg text-neutral-600">I can offer:</p>
		<div class="mt-12 grid gap-10 sm:grid-cols-3">
			{
				offerings.map(({ title, text }) => (
					<article class="border border-neutral-100 bg-white p-8 text-center shadow-sm">
						<h3 class="font-display text-2xl tracking-[0.1em] text-neutral-900 uppercase">
							{title}
						</h3>
						<div class="mx-auto mt-4 h-px w-10 bg-tangerine" />
						<p class="mt-4 leading-relaxed text-neutral-600">{text}</p>
					</article>
				))
			}
		</div>
	</section>

	<!-- Feng Shui Architecture -->
	<section class="bg-neutral-50">
		<div class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-20 lg:grid-cols-2">
			<div>
				<h2 class="font-display text-5xl text-sand italic">Feng Shui Architecture</h2>
				<p class="mt-6 text-lg leading-relaxed text-neutral-600">
					Zai Gua Ba-Zai, San He, Hou Tian Ba-Gua, Architecture designs and more.
				</p>
				<a
					href="/architecture"
					class="mt-8 inline-block text-sm font-medium tracking-[0.2em] text-tangerine uppercase underline-offset-4 hover:underline"
				>
					Learn more
				</a>
			</div>
			<Placeholder
				alt="Modern white house exterior with clean lines and a green lawn"
				class="aspect-[4/3] w-full"
			/>
		</div>
	</section>

	<!-- Tell me about your project -->
	<section class="mx-auto max-w-3xl px-6 py-20 text-center">
		<h2 class="font-display text-4xl text-neutral-900 italic">Tell me more about your project</h2>
		<p class="mt-6 leading-relaxed text-neutral-600">
			I am willing to participate in different projects where feng shui wisdom can be useful. Let
			me know what you have in mind and I'll help you through feng shui to get the most out of the
			energy and make sure that it flows better for you.
		</p>
		<a
			href="/contact"
			class="mt-8 inline-block bg-coral px-8 py-3 text-sm font-medium tracking-[0.2em] text-white uppercase transition-colors hover:bg-tangerine"
		>
			Get in touch
		</a>
	</section>

	<!-- Testimonials -->
	<section class="bg-sand">
		<div class="mx-auto grid max-w-6xl gap-12 px-6 py-20 sm:grid-cols-2">
			{
				testimonials.map(({ quote, author }) => (
					<blockquote class="text-center">
						<p class="text-xl tracking-[0.3em] text-white" aria-label="Five star rating">
							★★★★★
						</p>
						<p class="mt-6 font-display text-2xl leading-snug text-neutral-800 italic">
							{quote}
						</p>
						<footer class="mt-6 font-display text-lg text-neutral-700">{author}</footer>
					</blockquote>
				))
			}
		</div>
	</section>
</Layout>
